PORT=3001
JWT_SECRET=mude_esta_chave_em_producao_use_256bits
GEMINI_API_KEY=your_gemini_api_key_here
# Modelo Gemini opcional (quando o modelo não existir/for suportado, o sistema tenta um fallback)
GEMINI_MODEL=gemini-1.5-flash-latest
DB_PATH=./data/prontuario.db
UPLOAD_PATH=./uploads
DOCTOR_EMAIL=doctor@example.com
NODE_ENV=development

# Google Calendar (Agenda / Consultas)
# 1. Crie uma API key em https://console.cloud.google.com/apis/credentials
# 2. Ative a API "Google Calendar API" no projeto
GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key_here
GOOGLE_CALENDAR_ID=primary
