PORT=3001
JWT_SECRET=mude_esta_chave_em_producao_use_256bits

# Provedor de LLM: openrouter | gemini
# Se vazio: usa OpenRouter quando OPENROUTER_API_KEY estiver definida; senão Gemini.
LLM_PROVIDER=openrouter

# Google Gemini (só usado se LLM_PROVIDER=gemini ou se não houver OpenRouter)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter (https://openrouter.ai — SDK @openrouter/sdk)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=https://seu-dominio.com
# OPENROUTER_APP_TITLE=Luz Performance MVP

DB_PATH=./data/prontuario.db
UPLOAD_PATH=./uploads
DOCTOR_EMAIL=luzardi18@gmail.com
NODE_ENV=development

# Google Calendar (Agenda / Consultas)
# 1. Crie uma API key em https://console.cloud.google.com/apis/credentials
# 2. Ative a API "Google Calendar API" no projeto
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_ID=luzardi18@gmail.com

